{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "client/dist"
      }
    },
    {
      "src": "server/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server/index.js"
    },
    {
      "src": "/providers(.*)",
      "dest": "server/index.js"
    },
    {
      "src": "/bookings(.*)",
      "dest": "server/index.js"
    },
    {
      "src": "/login",
      "dest": "server/index.js",
      "methods": ["POST"]
    },
    {
      "src": "/register",
      "dest": "server/index.js",
      "methods": ["POST"]
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
